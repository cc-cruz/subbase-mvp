APP_ENV=local
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEON_AUTH_BASE_URL=https://your-project.neonauth.us-east-1.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=replace-with-a-32-byte-secret

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/subbase?schema=public
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/subbase?schema=public

RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=hello@subbase.app

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_STARTER=price_starter
STRIPE_PRICE_PROFESSIONAL=price_professional
STRIPE_PRICE_BUSINESS=price_business

INTUIT_CLIENT_ID=your_intuit_client_id
INTUIT_CLIENT_SECRET=your_intuit_client_secret
INTUIT_REDIRECT_URI=http://localhost:3000/api/integrations/quickbooks/callback
INTUIT_ENVIRONMENT=sandbox

ENCRYPTION_KEY=replace-with-a-32-byte-secret
LOG_LEVEL=info
